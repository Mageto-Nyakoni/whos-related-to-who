---
import type { FamilyDataset } from '../types/family';

type FamilyModule = {
  default: FamilyDataset;
};

const familyModules = import.meta.glob<FamilyModule>('/src/data/families/*.json', { eager: true });

const families = Object.entries(familyModules)
  .map(([filePath, module]) => {
    const familyId = filePath.split('/').pop()?.replace('.json', '');
    if (!familyId) return null;

    return {
      familyId,
      familyName: module.default.metadata.familyName
    };
  })
  .filter((family): family is NonNullable<typeof family> => Boolean(family))
  .sort((left, right) => left.familyName.localeCompare(right.familyName));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Family Not Found</title>
    <style>
      :root {
        color-scheme: dark;
        font-family: "Avenir Next", "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top, rgba(248, 113, 113, 0.14), transparent 24%),
          linear-gradient(180deg, #020617 0%, #0f172a 100%);
        color: #e2e8f0;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 1rem;
      }

      main {
        width: min(100%, 42rem);
        padding: 1.5rem;
        border-radius: 24px;
        background: rgba(15, 23, 42, 0.82);
        border: 1px solid rgba(248, 113, 113, 0.2);
      }

      h1 {
        margin: 0 0 0.5rem;
        font-size: clamp(2rem, 5vw, 3rem);
      }

      p {
        color: #cbd5e1;
        line-height: 1.6;
      }

      ul {
        padding-left: 1.2rem;
      }

      a {
        color: #7dd3fc;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>404: family not found</h1>
      <p>The requested family route does not exist. Try one of the generated family pages below.</p>
      <ul>
        {families.map((family) => (
          <li>
            <a href={`/family/${family.familyId}`}>{family.familyName}</a>
          </li>
        ))}
      </ul>
      <p><a href="/">Back to the family index</a></p>
    </main>
  </body>
</html>
